    "df = pd.DataFrame(data)\n",
    "\n",
    "def categorize(age):\n",
    "    if 10 <= age < 20:\n",
    "        return \"10대\"\n",
    "    elif 20 <= age < 30:\n",
    "        return \"20대\"\n",
    "    elif 30 <= age < 40:\n",
    "        return \"30대\"\n",
    "    else:\n",
    "        return \"40대 이상\"\n",
    "\n",
    "df['검사나이'] = df['나이'].apply(categorize)\n",
    "\n",
    "print(df)"
   ]
