   "source": [
    "def level(x):\n",
    "    if x > 0 and x <= 55:\n",
    "        return '하'\n",
    "    elif x > 55 and x <= 70:\n",
    "        return '중'\n",
    "    elif x > 70:\n",
    "        return '상'\n",
    "\n",
    "# 평가분류 변수 생성\n",
    "df['평가분류'] = df['평균'].apply(level)\n",
    "\n",
    "# 결과 출력\n",
    "df"
   ]
  },
